#!/usr/bin/env bash
# pre-push: tsc --noEmit 만 빠르게 돌려 main / PR 에 type error 가 새는 것을 차단.
# 우회하려면 의식적으로 `git push --no-verify` — AGENTS.md 룰: "특별히 사용자가 요청한 경우에만 우회".
#
# Round 11 (2026-05-04): adc2abb 이후 main 에 direct push 로 CI failure 4연속 무시된
# 사례 발견 — 그 회귀를 로컬에서 일찍 잡기 위해 도입.

set -e

remote="$1"
pnpm_cmd=()

if command -v pnpm >/dev/null 2>&1; then
  pnpm_cmd=("$(command -v pnpm)")
elif command -v corepack >/dev/null 2>&1; then
  pnpm_cmd=("$(command -v corepack)" pnpm)
else
  for candidate in "$HOME"/.nvm/versions/node/*/bin/pnpm "$HOME"/Library/pnpm/pnpm "$HOME"/.local/share/pnpm/pnpm; do
    if [ -x "$candidate" ]; then
      pnpm_cmd=("$candidate")
      break
    fi
  done
fi

if [ "${#pnpm_cmd[@]}" -eq 0 ]; then
  echo "❌ pre-push: pnpm 을 찾지 못했습니다 — push 중단"
  echo "   Git hook 환경의 PATH 에 pnpm 이 없습니다."
  echo "   해결: corepack enable 또는 PNPM_HOME/nvm bin 경로를 PATH 에 추가하세요."
  echo "   우회하려면: git push --no-verify  (의식적 선택일 때만)"
  exit 1
fi

case "${pnpm_cmd[0]}" in
  */pnpm)
    # GUI Git clients often run hooks with a minimal PATH. pnpm's shebang uses
    # `/usr/bin/env node`, so keep the matching Node bin beside pnpm visible.
    export PATH="$(dirname "${pnpm_cmd[0]}"):$PATH"
    ;;
esac

while read local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main)
      echo "[pre-push] main 으로 push — type check 강제"
      ;;
    *)
      echo "[pre-push] $remote_ref — type check 강제"
      ;;
  esac
done

if ! "${pnpm_cmd[@]}" exec node scripts/clean-next-dev-cache.mjs; then
  echo ""
  echo "❌ pre-push: Next dev cache 정리 실패 — push 중단"
  echo "   우회하려면: git push --no-verify  (의식적 선택일 때만)"
  exit 1
fi

if ! "${pnpm_cmd[@]}" exec tsc --noEmit; then
  echo ""
  echo "❌ pre-push: TypeScript 컴파일 실패 — push 중단"
  echo "   우회하려면: git push --no-verify  (의식적 선택일 때만)"
  exit 1
fi

echo "✅ pre-push: tsc --noEmit clean"
