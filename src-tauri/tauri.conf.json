{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Context Atlas",
  "version": "0.1.0",
  "identifier": "dev.jinan.context-atlas",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Context Atlas",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "script-src": "'self'",
        "worker-src": "'self' blob:",
        "style-src": "'unsafe-inline' 'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first codebase ontology workbench for Context Atlas",
    "longDescription": "Context Atlas is a local-first macOS app for opening a markdown ontology vault, editing codebase meaning, and handing the same graph to AI agents without a backend or login. The repository, CLI, and release assets remain under the oh-my-ontology project name.",
    "copyright": "Copyright © 2026 oh-my-ontology contributors",
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
