{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/block-npm-publish.sh"
          }
        ]
      },
      {
        "matcher": "exec_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/block-npm-publish.sh"
          }
        ]
      },
      {
        "matcher": "functions.exec_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/block-npm-publish.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/inject-ontology-summary.sh"
          }
        ]
      }
    ]
  }
}
