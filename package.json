{
  "name": "oh-my-ontology",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "sideEffects": [
    "*.css",
    "**/globals.css"
  ],
  "scripts": {
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true",
    "predev": "pnpm docs-vault:build",
    "dev": "next dev",
    "build": "pnpm docs-vault:build && next build",
    "docs-vault:build": "node scripts/build-docs-vault.mjs",
    "vault:validate": "node scripts/validate-vault.mjs",
    "vault:migrate": "node scripts/migrate-vault.mjs",
    "vault:audit": "node scripts/audit-vault-paths.mjs",
    "package:check": "node scripts/check-package-contracts.mjs && node --test scripts/check-package-contracts.test.mjs",
    "smoke:onboarding": "node scripts/smoke-clean-onboarding.mjs",
    "smoke:packed-cli": "node scripts/smoke-packed-cli.mjs",
    "benchmark": "node scripts/benchmark.mjs",
    "benchmark:scale": "node scripts/benchmark-scale.mjs",
    "dogfood:walk": "node scripts/dogfood-mcp-walk.mjs",
    "dogfood:test": "node --test scripts/dogfood-mcp-walk.test.mjs",
    "lint": "eslint",
    "bundle:check": "node scripts/check-bundle.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sigma/edge-curve": "^3.1.0",
    "@sigma/node-border": "^3.0.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-force": "^3.0.0",
    "d3-force-reuse": "^1.0.1",
    "framer-motion": "^12.38.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.74.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sigma": "^3.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
