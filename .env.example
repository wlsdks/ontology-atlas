# Firebase Web SDK 설정
# Firebase Console → 프로젝트 설정 → 일반 → 내 앱 → SDK 설정 및 구성에서 복사
#
# 사용법: 이 파일을 .env.local로 복사한 후 실제 값으로 채운다.
#   cp .env.example .env.local

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=aslan-project-map.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=aslan-project-map
# Optional. Default static export builds use seed/demo data and do not call
# Firestore during `next build`.
# ASLAN_BUILD_PROJECT_SOURCE=firestore
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=aslan-project-map.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# aslan-iam public auth (선택)
# 설정하면 이메일/비밀번호 로그인/회원가입은 JWT 세션 기반 IAM을 우선 사용합니다.
NEXT_PUBLIC_IAM_BASE_URL=

# 공개 데모 로그인 계정 (정적 사이트 특성상 공개 가능한 읽기 전용 계정만 권장)
NEXT_PUBLIC_DEMO_LOGIN_EMAIL=
NEXT_PUBLIC_DEMO_LOGIN_PASSWORD=

# 로컬 개발에서만 admin guard 우회 버튼 노출
# 1로 두고 localhost/127.0.0.1 에서만 동작
NEXT_PUBLIC_DEV_ADMIN_BYPASS=

# 로컬 emulator 연결
NEXT_PUBLIC_FIREBASE_USE_EMULATORS=
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=
NEXT_PUBLIC_FUNCTIONS_EMULATOR_HOST=
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=asia-northeast3

# 로컬 admin proxy origin
NEXT_PUBLIC_DEV_ADMIN_PROXY_ORIGIN=
