rules_version = '2';

// oh-my-ontology — Firestore Security Rules (single-user mode)
//
// 모델:
// - 1 명의 로그인 사용자가 자기 워크스페이스의 owner.
// - account / membership 개념 없음 (R5 라운드에서 entity + rules 제거).
// - 대부분의 컬렉션은 root path. 인증된 사용자가 자기 데이터를 직접 CRUD.
//
// 외부 노출 surface:
// - projects · categories · statuses · meta · ontologyClasses ·
//   ontologyRelations · knowledgePublic* · workspaceProjects (+hubs/nodes) :
//   누구나 읽기. 쓰기는 인증 사용자.
// - knowledgeDocuments / knowledgeApproved* : 인증 사용자만 읽기·쓰기.
// - knowledgeJobs / knowledgeChunks / knowledgeEvidence / knowledgeOutputs /
//   knowledgeReviews / knowledgeApprovalEvents / knowledgePublishes :
//   trusted server (Cloud Function Admin SDK) 만 write. client 는 read.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    match /statuses/{statusId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    match /meta/{document} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // M2 · 외부 HTTP API key. 평문 키는 hash 만 저장돼 firestore 노출돼도 사용
    // 불가. delete 는 차단 — revoke 후 audit 보존. revoke 는 revokedAt 만 set.
    match /apiKeys/{keyId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update: if isAuthed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revokedAt']);
      allow delete: if false;
    }

    // P0-B · Workspace > Project > Hub + Node 4-layer.
    // nodes 는 hubs sibling — `hubIds: string[]` 으로 N:M 참조.
    match /workspaceProjects/{projectId} {
      allow read: if true;
      allow create, update: if isAuthed();
      allow delete: if false;

      match /hubs/{hubId} {
        allow read: if true;
        allow write: if isAuthed();
      }

      match /nodes/{nodeId} {
        allow read: if true;
        allow write: if isAuthed();
      }
    }

    // 활동 로그 — append-only.
    match /projectActivity/{eventId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if false;
    }

    // 클라이언트 에러 — global-error/error.tsx 가 hydration·render 실패 시 append.
    match /clientErrors/{errorId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if false;
    }

    // 지식 문서 — 사용자 본인의 raw 문서. published 는 public read.
    match /knowledgeDocuments/{documentId} {
      allow read: if isAuthed()
        || (resource != null && resource.data.status == 'published');
      allow write: if isAuthed();
    }

    match /knowledgeDocumentVersions/{versionId} {
      allow read: if isAuthed();
      allow create: if isAuthed();
      allow update, delete: if false;
    }

    // 추출 파이프라인 — backend Cloud Function 만 write. client 는 read 만.
    match /knowledgeDocumentChunks/{chunkId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /knowledgeEvidence/{evidenceId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /knowledgeExtractionJobs/{jobId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /knowledgeExtractionOutputs/{outputId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /knowledgeReviews/{reviewId} {
      allow read, write: if isAuthed();
    }

    match /knowledgeReviewEvents/{eventId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /knowledgeApprovalEvents/{eventId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    // knowledgeApprovedNodes / knowledgeApprovedEdges — extraction-검수-승인
    // 경로의 canonical store. server (applyReviewActionCore) 가 기본 writer.
    // Manual editor v0 부터 client 가 source: "manual" 인 노드/엣지 직접 CRUD.
    match /knowledgeApprovedNodes/{nodeId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.source == "manual"
                    && request.resource.data.manualAuthor == request.auth.uid
                    && request.resource.data.kind in [
                      "project", "domain", "capability", "element", "document"
                    ]
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && (!('isStub' in request.resource.data)
                        || request.resource.data.isStub == false)
                    && !('pendingType' in request.resource.data)
                    && !('pendingFromId' in request.resource.data);
      allow update: if isAuthed()
                    && resource.data.source == "manual"
                    && resource.data.manualAuthor == request.auth.uid
                    && resource.data.isStub != true
                    && request.resource.data.source == "manual"
                    && request.resource.data.manualAuthor == request.auth.uid
                    && request.resource.data.kind == resource.data.kind
                    && !('deletedAt' in request.resource.data)
                    && !('deletedBy' in request.resource.data)
                    && !('deletedReason' in request.resource.data);
      allow delete: if isAuthed()
                    && resource.data.source == "manual"
                    && resource.data.manualAuthor == request.auth.uid
                    && resource.data.isStub != true;
    }

    match /knowledgeApprovedEdges/{edgeId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.source == "manual"
                    && request.resource.data.manualAuthor == request.auth.uid
                    && request.resource.data.from is string
                    && request.resource.data.from.size() > 0
                    && request.resource.data.to is string
                    && request.resource.data.to.size() > 0
                    && request.resource.data.type in [
                      "contains", "belongs_to", "depends_on",
                      "implements", "uses", "describes", "related_to"
                    ];
      allow update: if isAuthed()
                    && resource.data.source == "manual"
                    && resource.data.manualAuthor == request.auth.uid
                    && request.resource.data.source == "manual"
                    && request.resource.data.manualAuthor == request.auth.uid
                    && request.resource.data.from == resource.data.from
                    && request.resource.data.to == resource.data.to
                    && request.resource.data.type == resource.data.type
                    && !('deletedAt' in request.resource.data)
                    && !('deletedBy' in request.resource.data)
                    && !('deletedReason' in request.resource.data);
      allow delete: if isAuthed()
                    && resource.data.source == "manual"
                    && resource.data.manualAuthor == request.auth.uid;
    }

    match /knowledgePublishes/{publishId} {
      allow read: if isAuthed();
      allow write: if false;
    }

    match /knowledgePublicMeta/{documentId} {
      allow read: if true;
      allow write: if false;
    }

    match /knowledgePublicNodes/{nodeId} {
      allow read: if true;
      allow write: if false;
    }

    match /knowledgePublicEdges/{edgeId} {
      allow read: if true;
      allow write: if false;
    }

    // Ontology TBox — knowledge subsystem 의 schema 정의.
    // 누구나 읽기 가능 (공개 surface 가 클래스/관계 라벨 표시).
    match /ontologyClasses/{classId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    match /ontologyRelations/{relationId} {
      allow read: if true;
      allow write: if isAuthed();
    }

    // P1 Phase 1 — TBox versioning. immutable snapshot.
    match /ontologyTBoxVersions/{versionId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.classes is list
                    && request.resource.data.relations is list;
      allow update, delete: if false;
    }

    // 활성 TBox 포인터. single-user 에선 doc id == "current" 가 canonical
    // (data 마이그레이션 시 accountId-keyed → "current" 로 통합 예정).
    match /ontologyTBoxState/{stateId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed()
                           && request.resource.data.versionId is string
                           && request.resource.data.activatedBy == request.auth.uid;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
