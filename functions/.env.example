# Firebase Functions 환경변수 예시.
# 실제 값은 .env.local 에 복사해서 채운다 (.env.local 은 git 에서 제외됨).
#
# 프로덕션 배포 시에는 이 값을 Firebase Functions secret 으로 등록:
#   firebase functions:secrets:set GEMINI_API_KEY
#
# 이 파일 자체는 키를 담지 않고 형식만 보여준다.

# Google AI Studio 에서 발급. Gemini 문서 추출 adapter 가 사용.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
