{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-npm-publish.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/write-agent-activity.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/inject-ontology-summary.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/write-agent-activity.sh"
          }
        ]
      }
    ]
  }
}
